# e.g. nvim/.omc, wezterm/.omc, yazi/.omc).
.omc/
.firecrawl/

# Standalone AI/dev tool config dirs (top-level only).
/crush/
/devin/
/flutter/
/goose/
/opencode/
/vercel-plugin/
/fish/
